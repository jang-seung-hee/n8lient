# =============================================================================
# N8Lient 프론트엔드 로컬 개발 환경변수 템플릿 (.env.local)
# =============================================================================
#
# [보안 주의사항]
# 1. 이 파일은 브라우저 클라이언트에서 접근할 수 있는 환경변수만 정의합니다.
# 2. n8n API 토큰, Callback Secret, Firebase Admin 비공개키 등의 민감 정보는 
#    프론트엔드 환경변수(.env.local 등)에 절대 포함되어서는 안 됩니다.
# 3. 민감한 서버용 설정은 Cloud Run 배포 파일(env.yaml)에서 별도로 관리됩니다.
# 4. 이 템플릿을 복사하여 '.env.local' 파일을 생성하고 빈 값을 채워주세요.

# Firebase Web SDK 설정 (브라우저 공개 가능 설정)
NEXT_PUBLIC_FIREBASE_API_KEY=your-firebase-api-key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your-project-id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your-sender-id
NEXT_PUBLIC_FIREBASE_APP_ID=1:your-sender-id:web:your-app-unique-id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your-measurement-id

# 서비스 홈 URL
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Cloud Run Gateway API 엔드포인트 URL
# 브라우저는 n8n 웹훅 서버에 직접 통신하지 않고 Gateway를 경유합니다.
NEXT_PUBLIC_GATEWAY_BASE_URL=https://n8lient-gateway-xxxx.asia-northeast3.run.app
