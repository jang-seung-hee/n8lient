rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // 로그인 및 사용자 데이터 조회 헬퍼 함수
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserData(uid) {
      return get(/databases/$(database)/documents/users/$(uid)).data;
    }

    function getMyUser() {
      return getUserData(request.auth.uid);
    }
    
    function isCompanyAdmin() {
      let myUser = getMyUser();
      return myUser != null && 'role' in myUser && myUser.role == 'company_admin';
    }

    // 1. 사용자 정보 (users) 규칙
    match /users/{uid} {
      // 본인은 조회 가능하며, 회사 관리자 및 운영자도 조회가 가능
      allow get: if isAuthenticated() && (
        request.auth.uid == uid ||
        (isCompanyAdmin() && getMyUser().clientId == resource.data.clientId) ||
        getMyUser().role == 'operator'
      );
      
      // 운영자는 이메일로 사용자 조회(ownerAdminUid 매핑)를 위해 list 허용, 회사 관리자는 자기 회사 소속만 list 허용
      allow list: if isAuthenticated() && (
        (isCompanyAdmin() && resource.data.clientId == getMyUser().clientId) ||
        getMyUser().role == 'operator'
      );
      
      // 최초 가입 시 생성이 가능
      allow create: if isAuthenticated() && request.auth.uid == uid;
        
      // 사용자가 본인의 중요 정보(role, approvalStatus, clientId)를 임의로 오동작/해킹 수정하지 못하도록 조건 제약
      allow update: if isAuthenticated() && (
        (request.auth.uid == uid && (
          // [가입 신청 허용 조건] 기존 clientId가 없고, 신규 clientId가 배정되며, 상태가 pending인 최초의 경우만 허용
          (resource.data.clientId == null && request.resource.data.clientId != null && request.resource.data.approvalStatus == 'pending' && request.resource.data.role == 'user') ||
          // [승인 요청 취소 조건] 기존 clientId가 존재하고, 취소 시 clientId가 null로 변경되며, 상태가 pending -> no_company로 변경되는 경우 허용 (role: user 한정, 변경 필드 제한)
          (resource.data.clientId != null && 
           request.resource.data.clientId == null && 
           resource.data.approvalStatus == 'pending' && 
           request.resource.data.approvalStatus == 'no_company' && 
           resource.data.role == 'user' && 
           request.resource.data.role == 'user' &&
           request.resource.data.diff(resource.data).affectedKeys().hasOnly(['approvalStatus', 'clientId', 'updatedAt'])) ||
          // [일반 정보 수정 조건] 중요 필드(role, approvalStatus, clientId)가 변경되지 않은 경우만 허용
          (request.resource.data.role == resource.data.role && 
           request.resource.data.approvalStatus == resource.data.approvalStatus && 
           request.resource.data.clientId == resource.data.clientId)
        )) ||
        // 회사 관리자가 소속 사용자의 상태를 승인/거절 처리할 수 있음 (최소 필드 수정 및 권한상승 방지 적용)
        (isCompanyAdmin() && 
         request.auth.uid != uid &&
         resource.data.clientId == getMyUser().clientId &&
         request.resource.data.clientId == getMyUser().clientId &&
         resource.data.role == 'user' &&
         request.resource.data.role == 'user' &&
         request.resource.data.email == resource.data.email &&
         request.resource.data.displayName == resource.data.displayName &&
         request.resource.data.uid == resource.data.uid &&
         request.resource.data.createdAt == resource.data.createdAt) ||
        // 총괄운영자는 모든 사용자의 역할 및 상태를 수정할 수 있음
        getMyUser().role == 'operator'
      );
      
      allow delete: if false;
    }

    // 1.5. 회사 기본 정보 (clients) 규칙
    match /clients/{clientId} {
      allow get: if isAuthenticated() && (
        getMyUser().role == 'operator' ||
        (
          getMyUser().role == 'company_admin' &&
          getMyUser().clientId == clientId &&
          getMyUser().approvalStatus == 'approved'
        )
      );
      allow list: if isAuthenticated() && getMyUser().role == 'operator';
      allow create, delete: if isAuthenticated() && getMyUser().role == 'operator';
      allow update: if isAuthenticated() && (
        getMyUser().role == 'operator' ||
        (
          getMyUser().role == 'company_admin' &&
          getMyUser().clientId == clientId &&
          getMyUser().approvalStatus == 'approved' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'companyDisplayName',
            'contactName',
            'contactPhone',
            'address',
            'homepageUrl',
            'description',
            'defaultTimezone',
            'defaultReportEmail',
            'updatedAt'
          ])
        )
      );
    }

    // 2. 회사코드 룩업 (companyCodeLookups) 규칙
    match /companyCodeLookups/{normalizedCode} {
      allow get: if isAuthenticated();
      allow write: if isAuthenticated() && getMyUser().role == 'operator';
      allow list: if false;
    }

    // 3. 회사 가입 승인 요청 (companyJoinRequests) 규칙
    match /companyJoinRequests/{requestId} {
      // 사용자는 본인 uid로 가입 승인 요청을 생성할 수 있음
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      
      // 본인이거나, 본인 회사의 관리자인 경우 get 가능
      allow get: if isAuthenticated() && (
        resource == null || 
        resource.data.uid == request.auth.uid || 
        (isCompanyAdmin() && getMyUser().clientId == resource.data.clientId) ||
        getMyUser().role == 'operator'
      );
      
      // 본인의 가입 요청 리스트 조회 또는 해당 회사의 관리자가 승인 대기 리스트를 쿼리할 수 있도록 허용 (list)
      allow list: if isAuthenticated();
      
      // 사용자는 본인의 요청 문서를 취소(cancelled) 가능하며, 회사 관리자도 일반 user 승인/거절 상태(status) 업데이트 가능
      allow update: if isAuthenticated() && (
        (resource.data.uid == request.auth.uid && 
         request.resource.data.uid == request.auth.uid &&
         resource.data.status == 'pending' &&
         request.resource.data.status == 'cancelled') ||
        (isCompanyAdmin() && 
         getMyUser().clientId == resource.data.clientId &&
         (!('requestedRole' in resource.data) || resource.data.requestedRole == 'user')) ||
        getMyUser().role == 'operator'
      );
        
      allow delete: if false;
    }

    // 4. 자동화 템플릿 (workflowTemplates) 규칙
    match /workflowTemplates/{workflowKey} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && getMyUser().role == 'operator';
    }

    // 5. 회사별 계약 자동화 (clientContracts) 규칙
    match /clientContracts/{contractId} {
      allow read: if isAuthenticated() && (
        getMyUser().role == 'operator' || 
        getMyUser().clientId == resource.data.clientId
      );
      allow write: if isAuthenticated() && getMyUser().role == 'operator';
    }

    // 6. 실제 등록 자동화 설정 (clientAutomations) 규칙
    match /clientAutomations/{automationId} {
      allow read: if isAuthenticated() && (
        getMyUser().role == 'operator' ||
        (isCompanyAdmin() && getMyUser().clientId == resource.data.clientId) ||
        (getMyUser().clientId == resource.data.clientId && resource.data.enabled == true && resource.data.configStatus == 'configured')
      );
      allow write: if isAuthenticated() && (
        getMyUser().role == 'operator' ||
        (isCompanyAdmin() && getMyUser().clientId == request.resource.data.clientId)
      );
    }

    // 6.5 사용자 개인 자동화 설정값 (userAutomationSettings) 규칙
    // [1차 조치] 운영자(operator)는 getWorkflowTemplateUsageSummary 집계 조회를 위해 read/list 허용
    // [후속 과제] 향후 서버 API / Admin SDK에서 count만 반환하는 구조로 전환 예정
    match /userAutomationSettings/{settingId} {
      allow read: if isAuthenticated() && (
        getMyUser().role == 'operator' ||
        resource == null ||
        resource.data.uid == request.auth.uid
      );
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow update: if isAuthenticated() && resource.data.uid == request.auth.uid && request.resource.data.uid == request.auth.uid;
      allow delete: if isAuthenticated() && (
        resource.data.uid == request.auth.uid ||
        (
          getMyUser().role == 'operator' &&
          resource.data.get('isTestSetting', true) == true &&
          exists(/databases/$(database)/documents/workflowTemplates/$(resource.data.workflowKey)) &&
          get(/databases/$(database)/documents/workflowTemplates/$(resource.data.workflowKey)).data.status == 'draft'
        )
      );
    }

    // 7. 자동화 실행 이력 (submissions) 규칙
    match /submissions/{submissionId} {
      allow create: if false; // 클라이언트단 직접 생성 금지 (Gateway에서 백엔드 어드민 SDK로만 생성 가능)
      
      allow read: if isAuthenticated() && (
        resource.data.uid == request.auth.uid ||
        (isCompanyAdmin() && getMyUser().clientId == resource.data.clientId) ||
        getMyUser().role == 'operator'
      );
      
      allow update: if false;
      allow delete: if isAuthenticated() && 
        getMyUser().role == 'operator' &&
        resource.data.get('isTestExecution', true) == true &&
        exists(/databases/$(database)/documents/workflowTemplates/$(resource.data.workflowKey)) &&
        get(/databases/$(database)/documents/workflowTemplates/$(resource.data.workflowKey)).data.status == 'draft';
    }

    // 8. 일회성 업로드 세션 (uploadSessions) 규칙 - 클라이언트 접근 원천 차단
    match /uploadSessions/{sessionId} {
      allow read, write: if false;
    }

    // 9. 회사 공개 프로필 (clientPublicProfiles) 규칙
    match /clientPublicProfiles/{clientId} {
      allow get: if isAuthenticated() && (
        getMyUser().role == 'operator' ||
        (
          getMyUser().clientId == clientId &&
          getMyUser().approvalStatus == 'approved'
        )
      );
      allow list: if isAuthenticated() && getMyUser().role == 'operator';
      allow create, delete: if isAuthenticated() && getMyUser().role == 'operator';
      allow update: if isAuthenticated() && (
        getMyUser().role == 'operator' ||
        (
          getMyUser().role == 'company_admin' &&
          getMyUser().clientId == clientId &&
          getMyUser().approvalStatus == 'approved' &&
          request.resource.data.diff(resource.data).affectedKeys().hasOnly([
            'companyDisplayName',
            'contactName',
            'contactPhone',
            'homepageUrl',
            'description',
            'updatedAt'
          ])
        )
      );
    }

  }
}

