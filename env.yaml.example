# =============================================================================
# N8Lient Gateway Cloud Run 배포용 환경변수 템플릿 (env.yaml)
# =============================================================================
#
# [운영 주의사항]
# 1. 이 파일은 Cloud Run 배포 시 '--env-vars-file' 옵션으로 주입됩니다.
# 2. 민감한 비밀 자격증명이 포함되므로 절대 Git에 커밋하지 마십시오.
# 3. 개별 워크플로우를 위한 N8N_WEBHOOK_PATH_* 환경변수는 더 이상 필요하지 않습니다.
#    (Gateway가 /webhook/{webhookSecretId} 형태로 웹훅 경로를 자동 조합합니다)

# Firebase Admin SDK 설정
# 게이트웨이가 클라이언트의 Firebase Auth ID Token을 검증하고,
# Firestore를 어드민 권한으로 조회하기 위해 사용합니다.
FIREBASE_ADMIN_PROJECT_ID: "n8lient"
FIREBASE_ADMIN_CLIENT_EMAIL: "firebase-adminsdk-xxxxx@n8lient.iam.gserviceaccount.com"
# YAML 배포 시 줄바꿈 이스케이프(\n) 처리에 주의하여 백슬래시 2개(\\n)를 사용해야 정상 주입됩니다.
FIREBASE_ADMIN_PRIVATE_KEY: "-----BEGIN PRIVATE KEY-----\\n...\\n-----END PRIVATE KEY-----\\n"

# n8n 서버 단위 설정 (workflowTemplates.n8nServerKey 값과 매핑)
# n8nServerKey가 'main'인 워크플로우가 바라볼 n8n 서버 설정입니다.
# 만약 새로운 n8n 서버를 추가한다면 N8N_SERVER_{KEY}_BASE_URL 형태로 정의하면 됩니다.
N8N_SERVER_MAIN_BASE_URL: "https://n8n.rentaltalk.kr"
N8N_SERVER_MAIN_TOKEN: "n8n_tok_main_교체필요"

# n8n callback 검증용 Secret (n8n ➡️ Gateway 결과 콜백 수신 시 보안 검증에 사용)
# n8n 워크플로우가 Gateway 콜백 API를 호출할 때 Authorization Bearer 헤더 값으로 전달하며,
# 이 설정값과 대조하여 검증합니다.
N8N_CALLBACK_SECRET: "cb_sec_key_교체필요"

# Gateway 자체 배포 주소 URL
# n8n 웹훅 호출 시 전달할 payload.callbackUrl을 자동 생성할 때 사용합니다.
GATEWAY_BASE_URL: "https://n8lient-gateway-xxxx.asia-northeast3.run.app"

# 업로드 파일 용량 제한 (단위: MB, 기본값: 10)
MAX_UPLOAD_MB: "10"

# Gateway CORS 허용 도메인 (브라우저에서 직접 게이트웨이 호출 시 CORS 허용할 도메인 쉼표 구분 목록)
ALLOWED_ORIGINS: "https://n8lient.netlify.app,http://localhost:3000"

# [선택사항: 특수 워크플로우 예외 경로 처리]
# 기본적으로 webhookSecretId를 사용하여 '/webhook/{webhookSecretId}' 형태로 경로가 자동 생성됩니다.
# 만약 특정 워크플로우에 대해서만 n8n 웹훅 경로를 다르게 맵핑해야 한다면 아래 오버라이드 환경변수를 추가하십시오.
# (이때 변수명 형식은 N8N_WEBHOOK_PATH_OVERRIDE_{WEBHOOK_SECRET_ID 대문자 치환} 입니다. 예: n8lient-idea-catcher -> N8LIENT_IDEA_CATCHER)
# N8N_WEBHOOK_PATH_OVERRIDE_SPECIAL_WORKFLOW: "/webhook/custom-special-path"
